{
  "css.validate": false,
  "editor.tabSize": 2,
  "editor.insertSpaces": true,
  "editor.indentSize": "tabSize",
  "editor.codeActionsOnSave": {
    "source.fixAll.biome": "always",
    "source.organizeImports.biome": "always",
    "source.removeUnusedImports": "always"
  },
  "files.associations": {
    "*.prototools": "toml"
  },
  "files.watcherExclude": {
    "**/routeTree.gen.ts": true
  },
  "search.exclude": {
    "**/routeTree.gen.ts": true
  },
  "files.readonlyInclude": {
    "**/routeTree.gen.ts": true
  },
  "[yaml,yml]": {
    "editor.defaultFormatter": "redhat.vscode-yaml"
  },
  "[toml]": {
    "editor.defaultFormatter": "tamasfe.even-better-toml"
  },
  "[svg]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[css]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[html]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[jsonc]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[json]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[typescriptreact]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "[javascript]": {
    "editor.defaultFormatter": "biomejs.biome"
  },
  "cSpell.language": "en,fr",
  "cSpell.words": [
    "Abatan",
    "argjson",
    "btca",
    "bunx",
    "carere",
    "cmdk",
    "cocogitto",
    "codegen",
    "delimoov",
    "endswith",
    "eplightning",
    "esnext",
    "fontsource",
    "fromjson",
    "github",
    "grpcs",
    "httpapi",
    "inlang",
    "kobalte",
    "kojo",
    "LLMS",
    "moonrepo",
    "outdir",
    "paraglide",
    "pipefail",
    "preheader",
    "prototools",
    "reui",
    "shadcn",
    "smol",
    "solidjs",
    "subsecond",
    "tailwindcss",
    "tanstack",
    "tsgo",
    "uidx",
    "unixepoch",
    "vitest",
    "zstd"
  ],
  "js/ts.updateImportsOnFileMove.enabled": "always",
  "js/ts.updateImportsOnPaste.enabled": true,
  "js/ts.experimental.useTsgo": true,
  "js/ts.tsdk.path": "node_modules/@typescript/native-preview/lib",
  "tailwindCSS.classAttributes": ["class"],
  "tailwindCSS.classFunctions": ["cva", "clsx", "cn"],
  "tailwindCSS.experimental.configFile": {
    "packages/design-system/src/styles.css": "packages/design-system/**/*",
    "apps/admin/src/styles.css": "apps/visualizer/src/**/*"
  }
}
